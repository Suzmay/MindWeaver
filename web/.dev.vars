# Cloudflare Workers 本地开发配置
# 本文件仅用于本地开发，不会提交到版本控制系统

# KV 命名空间 ID（本地开发时使用占位符，Wrangler 会自动创建本地 KV）
# 生产环境请在 Cloudflare Dashboard 中获取真实 ID
KV_ID=local-development
KV_PREVIEW_ID=local-development-preview
WORKS_KV_ID=local-works
WORKS_KV_PREVIEW_ID=local-works-preview

# R2 存储桶配置（本地开发时使用占位符）
R2_BUCKET_NAME=local-assets
R2_PREVIEW_BUCKET_NAME=local-assets-preview
